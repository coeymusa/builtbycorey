{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/case/mcu", "destination": "/case/mcu.html" },
    { "source": "/case/mooncake", "destination": "/case/mooncake.html" },
    { "source": "/case/rugby-unlocked", "destination": "/case/rugby-unlocked.html" },
    { "source": "/case/promptmysite", "destination": "/case/promptmysite.html" },
    { "source": "/case/lonsdale", "destination": "/case/lonsdale.html" },
    { "source": "/notes/one-engineer", "destination": "/notes/one-engineer.html" },
    { "source": "/notes/wordpress-rankings", "destination": "/notes/wordpress-rankings.html" },
    { "source": "/notes/regulated-discipline", "destination": "/notes/regulated-discipline.html" },
    { "source": "/notes/why-i-left-the-bank", "destination": "/notes/why-i-left-the-bank.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/styles.css",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    },
    {
      "source": "/",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    },
    {
      "source": "/index.html",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    }
  ]
}
